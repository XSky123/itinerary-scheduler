    "check": "tsc --noEmit && node scripts/verify-behavior.mjs && vite build --logLevel error"
  },
  "dependencies": {
    "dayjs": "^1.11.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite-plugin-singlefile": "^2.3.3",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.6"
  }
}
