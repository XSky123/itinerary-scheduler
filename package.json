{
  "name": "itinerary-scheduler",
  "version": "1.2.0",
  "description": "约束驱动的可视化行程排程工具",
  "license": "MIT",
  "homepage": "https://xsky123.github.io/itinerary-scheduler/",
  "repository": {
    "type": "git",
    "url": "https://github.com/xsky123/itinerary-scheduler.git"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:single": "vite build --logLevel error",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
